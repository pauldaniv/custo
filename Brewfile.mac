# Mac-only — casks, fonts, GUI apps
# Note: font casks live in the main homebrew/cask tap now; homebrew/cask-fonts was merged in and deprecated.

cask "ghostty"
cask "font-jetbrains-mono-nerd-font"

# pyenv's suggested build environment for compiling Pythons on macOS
# https://github.com/pyenv/pyenv/wiki#suggested-build-environment
brew "openssl@3"
brew "readline"
brew "sqlite3"
brew "xz"
brew "zlib"
